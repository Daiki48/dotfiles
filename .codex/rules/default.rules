# ============================================================
# Git: 書き込み系は全面禁止（Daiki が手動で実施する）
#   代表的な変更操作を rules で拒否し、未知の操作は hook の allowlist で拒否する
# ============================================================
prefix_rule(pattern=["git", "add"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "commit"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "push"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "pull"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "fetch"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "merge"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "rebase"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "reset"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "stash"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "cherry-pick"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "checkout"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "switch"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "restore"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "clean"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "revert"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "rm"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "mv"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "apply"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "am"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "tag"], decision="forbidden", justification="Git 書き込み系は Daiki が実施する")
prefix_rule(pattern=["git", "config"], decision="forbidden", justification="Git 設定の変更は Daiki が実施する")
prefix_rule(pattern=["git", "worktree"], decision="forbidden", justification="worktree とブランチの変更は Daiki が実施する")
prefix_rule(pattern=["git", "submodule"], decision="forbidden", justification="submodule の変更は Daiki が実施する")
prefix_rule(pattern=["git", ["gc", "prune"]], decision="forbidden", justification="Git リポジトリの変更は Daiki が実施する")

# ============================================================
# Git: 読み取り系は確認なしで実行可
#   読み書き両用の branch/remote は hook 側で読み取り用途のみ許可する
# ============================================================
prefix_rule(pattern=["git", ["status", "log", "diff", "show", "rev-parse", "blame", "shortlog", "describe", "reflog", "ls-files", "ls-tree", "cat-file", "rev-list", "merge-base", "name-rev", "grep"]], decision="allow", justification="読み取り専用 Git 操作は安全")

# ============================================================
# GitHub CLI: Issue 管理と読み取り専用操作だけを許可する
#   詳細な引数検査と未知の変更操作の拒否は PreToolUse hook で行う
# ============================================================
prefix_rule(pattern=["gh", "issue", ["list", "status", "view", "create", "edit", "comment", "close", "reopen", "pin", "unpin", "lock", "unlock", "transfer"]], decision="allow", justification="GitHub Issue は仕様・進捗・実装記録として Codex から管理できる")
prefix_rule(pattern=["gh", "issue", ["develop", "delete"]], decision="forbidden", justification="ブランチ作成と Issue 削除は許可しない")
prefix_rule(pattern=["gh", "pr", ["create", "merge", "close", "reopen", "edit", "comment", "review", "ready", "lock", "unlock", "update-branch", "checkout"]], decision="forbidden", justification="PR とブランチの変更は Daiki が実施する")
prefix_rule(pattern=["gh", "repo", ["create", "delete", "rename", "archive", "fork", "sync"]], decision="forbidden", justification="リポジトリの変更は許可しない")
prefix_rule(pattern=["gh", "run", ["cancel", "delete", "rerun"]], decision="forbidden", justification="Actions run の変更は許可しない")
prefix_rule(pattern=["gh", "workflow", ["run", "enable", "disable"]], decision="forbidden", justification="Workflow の変更は許可しない")
prefix_rule(pattern=["gh", "release", ["create", "delete", "edit", "upload"]], decision="forbidden", justification="Release の変更は許可しない")

# ============================================================
# 破壊的コマンド: 削除は必ず Daiki に確認、移動・リネームは許可
# ============================================================
prefix_rule(pattern=["rm"], decision="prompt", justification="削除操作のため、実行前に Daiki の確認が必要")
prefix_rule(pattern=["rmdir"], decision="prompt", justification="削除操作のため、実行前に Daiki の確認が必要")
prefix_rule(pattern=["mv"], decision="allow", justification="削除の代替としてリネーム・退避は許可")

# ============================================================
# 既存の許可コマンド（維持）
# ============================================================
prefix_rule(pattern=["curl"], decision="allow")
prefix_rule(pattern=["tmux", "source-file"], decision="allow")
prefix_rule(pattern=["tmux", "show-options"], decision="allow")
prefix_rule(pattern=["tmux", "display-message"], decision="allow")
prefix_rule(pattern=["rg", "-n", "javascript:|vbscript:|on[a-z]+\\s*=|<iframe|<object|<embed|<base|data:text/html"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["cargo", "fmt"], decision="allow")
prefix_rule(pattern=["cargo", "info"], decision="allow", justification="crate 情報の取得は非破壊的")
prefix_rule(pattern=["cargo", "check"], decision="allow")
prefix_rule(pattern=["cargo", "build"], decision="allow")
prefix_rule(pattern=["make", "build"], decision="allow")
prefix_rule(pattern=["cargo", "test"], decision="allow")
prefix_rule(pattern=["claude", "-p"], decision="allow")
prefix_rule(pattern=["npm", "audit"], decision="allow")
prefix_rule(pattern=["env", "-u", "NO_COLOR", "make", "dev-no-open", "DEV_PORT=8121"], decision="allow")
prefix_rule(pattern=["env", "-u", "NO_COLOR", "make", "dev-no-open", "DEV_PORT=8122"], decision="allow")
prefix_rule(pattern=["fuser", "-k", "8122/tcp"], decision="allow")
prefix_rule(pattern=["env", "-u", "NO_COLOR", "make", "dev-no-open", "DEV_PORT=8123"], decision="allow")
prefix_rule(pattern=["fuser", "-k", "9224/tcp"], decision="allow")
prefix_rule(pattern=["gh", "run", "view", "27095755052", "--log"], decision="allow")
prefix_rule(pattern=["npx", "--yes", "wrangler@4.98.0"], decision="allow")
prefix_rule(pattern=["pkill", "-f", "wrangler.*tail typecraft-worker-production"], decision="allow")
prefix_rule(pattern=["make", "dev-no-open"], decision="allow")
prefix_rule(pattern=["/home/daiki/Android/Sdk/emulator/emulator-check"], decision="allow")
prefix_rule(pattern=["cargo", "test", "--workspace", "--exclude", "kakiro-web"], decision="allow")
prefix_rule(pattern=["trunk", "build"], decision="allow")
prefix_rule(pattern=["/usr/bin/zsh", "-lc", "NO_COLOR=false trunk build"], decision="allow")
prefix_rule(pattern=["timeout", "90s", "make", "dev"], decision="allow")
prefix_rule(pattern=["make", "down"], decision="allow")
prefix_rule(pattern=["cargo", "tauri", "android", "init"], decision="allow")
prefix_rule(pattern=["timeout", "180s", "make", "dev-android"], decision="allow")
prefix_rule(pattern=["make", "test"], decision="allow")
prefix_rule(pattern=["timeout", "60s", "make", "dev"], decision="allow")
